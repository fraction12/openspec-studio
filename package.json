{
  "name": "openspec-studio",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first desktop workbench for inspecting OpenSpec repositories.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fraction12/openspec-studio.git"
  },
  "homepage": "https://github.com/fraction12/openspec-studio#readme",
  "bugs": {
    "url": "https://github.com/fraction12/openspec-studio/issues"
  },
  "keywords": [
    "openspec",
    "spec-driven-development",
    "tauri",
    "react",
    "desktop",
    "local-first"
  ],
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "tsc --noEmit",
    "lint": "eslint . && node scripts/verify-module-seams.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf:fixture": "node scripts/create-large-openspec-fixture.mjs --reset",
    "perf:measure": "node scripts/measure-openspec-workspace.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
